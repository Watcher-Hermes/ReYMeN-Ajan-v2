# ReYMeN Agent — API Key Yapilandirmasi
# Kullanacagin provider'in API key'ini buraya ekle.
# .env dosyasi GITIGNORE'dadir, hicbir zaman repoya eklenmez.

# ZORUNLU: En az bir provider
DEEPSEEK_API_KEY=ornek_buraya_key_yaz
# OPENROUTER_API_KEY=ornek_buraya_key_yaz

# OPSIYONEL: Diger provider'lar
# ANTHROPIC_API_KEY=ornek_buraya_key_yaz
# OPENAI_API_KEY=ornek_buraya_key_yaz
# XAI_API_KEY=ornek_buraya_key_yaz
# GROQ_API_KEY=ornek_buraya_key_yaz
# XIAOMI_API_KEY=ornek_buraya_key_yaz

# OPSIYONEL: Telegram bot token'i
# TELEGRAM_BOT_TOKEN=0000000000:ornek_buraya_token_yaz

# OPSIYONEL: Harici servisler
# FIRECRAWL_API_KEY=ornek_buraya_key_yaz
# PERPLEXITY_API_KEY=ornek_buraya_key_yaz
# FAL_KEY=ornek_buraya_key_yaz
