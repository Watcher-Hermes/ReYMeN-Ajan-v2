# ReYMeN Sandbox Image
FROM python:3.11-slim

# Sistem paketleri (minimum)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Çalışma dizini
WORKDIR /sandbox

# Kullanıcı: sandbox (root yetkisi yok)
RUN useradd -m -u 1000 sandbox && chown sandbox:sandbox /sandbox
USER sandbox

# Giriş noktası
ENTRYPOINT ["python", "-u", "-c"]
CMD ["print('Sandbox ready')"]
